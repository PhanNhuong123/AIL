{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIL IDE",
  "version": "0.4.0",
  "identifier": "dev.ail.ide",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "AIL IDE",
        "label": "main",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 680,
        "decorations": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
